<Window x:Class="M365TfsSync.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:M365TfsSync.Converters"
        Title="M365 TFS 行事曆同步工具"
        Width="900" Height="650"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── 身分驗證區 ── -->
        <GroupBox Grid.Row="0" Header="身分驗證" Margin="0,0,0,8" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 驗證方式選擇：帳號密碼優先，Windows 整合驗證 disabled -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="驗證方式：" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <RadioButton Content="帳號密碼驗證"
                                 IsChecked="{Binding IsPasswordAuth, Mode=TwoWay}"
                                 GroupName="AuthMode" Margin="0,0,16,0" VerticalAlignment="Center"/>
                    <RadioButton Content="Windows 整合驗證"
                                 IsChecked="{Binding IsWindowsAuth, Mode=TwoWay}"
                                 IsEnabled="False"
                                 GroupName="AuthMode" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 帳號密碼輸入（僅帳號密碼模式顯示） -->
                <Grid Grid.Row="1" Visibility="{Binding IsUsernamePasswordMode, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="帳號：" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Grid.Column="1" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                    <TextBlock Grid.Column="2" Text="密碼：" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <PasswordBox Grid.Column="3" x:Name="PasswordBox" Margin="0,0,0,0"/>
                </Grid>

                <!-- 登入狀態與按鈕 -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap" Foreground="DarkBlue"/>
                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0"
                               Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibility}}">
                        <Run Text="已登入："/>
                        <Run Text="{Binding LoggedInUser, Mode=OneWay}" FontWeight="Bold"/>
                    </TextBlock>
                    <Button Grid.Column="2" Content="登入" Command="{Binding LoginCommand}"
                            Width="70" Margin="0,0,8,0"
                            Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}"/>
                    <Button Grid.Column="3" Content="登出" Command="{Binding LogoutCommand}"
                            Width="70" Margin="0,0,8,0"
                            Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibility}}"/>
                    <Button Grid.Column="4" Content="⚙ 設定" Command="{Binding OpenSettingsCommand}"
                            Width="70"/>
                </Grid>
            </Grid>
        </GroupBox>

        <!-- ── 查詢條件區 ── -->
        <GroupBox Grid.Row="1" Header="查詢條件" Margin="0,0,0,8" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 第一行：Team + Sprint + Area（先選 TFS 資訊） -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Team：" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Width="150"
                              ItemsSource="{Binding Teams}"
                              SelectedItem="{Binding SelectedTeam}"
                              DisplayMemberPath="Name"
                              Margin="0,0,12,0"
                              IsEnabled="{Binding IsLoading, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}"/>
                    <TextBlock Text="Sprint：" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Width="200"
                              ItemsSource="{Binding Sprints}"
                              SelectedItem="{Binding SelectedSprint}"
                              DisplayMemberPath="DisplayName"
                              Margin="0,0,12,0"
                              IsEnabled="{Binding IsLoading, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}"/>
                    <TextBlock Text="Area：" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Width="200"
                              ItemsSource="{Binding Areas}"
                              SelectedItem="{Binding SelectedArea}"
                              DisplayMemberPath="DisplayName"
                              IsEnabled="{Binding IsLoading, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}"/>
                </StackPanel>

                <!-- 第二行：日期（由 Sprint 自動帶入）+ ICS 按鈕 -->
                <StackPanel Grid.Row="1" Orientation="Horizontal">
                    <TextBlock Text="開始日期：" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <DatePicker SelectedDate="{Binding StartDate}" Width="140" Margin="0,0,12,0"/>
                    <TextBlock Text="結束日期：" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <DatePicker SelectedDate="{Binding EndDate}" Width="140" Margin="0,0,12,0"/>
                    <Button Content="取得會議" IsEnabled="False" Width="80" Margin="0,0,8,0"/>
                    <Button Content="📂 載入 ICS" Command="{Binding LoadIcsCommand}" Width="90" Margin="0,0,8,0"/>
                    <Button Content="📊 載入 CSV" Command="{Binding LoadCsvCommand}" Width="90" Margin="0,0,0,0"/>
                    <TextBlock Text="{Binding DateValidationError}" Foreground="Red"
                               VerticalAlignment="Center" Margin="12,0,0,0"
                               Visibility="{Binding DateValidationError, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- ── 會議清單區 ── -->
        <GroupBox Grid.Row="2" Header="會議清單" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 工具列 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Content="全選" Command="{Binding SelectAllCommand}" Width="60" Margin="0,0,8,0"/>
                    <Button Content="全部取消" Command="{Binding DeselectAllCommand}" Width="70" Margin="0,0,16,0"/>
                    <TextBlock Text="載入中..." VerticalAlignment="Center"
                               Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                               Foreground="Gray"/>
                </StackPanel>

                <!-- DataGrid -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding CalendarEvents}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="False"
                          SelectionMode="Single"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <!-- 勾選框 -->
                        <DataGridTemplateColumn Header="" Width="40">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                              IsEnabled="{Binding IsSelectable}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- 會議主旨 -->
                        <DataGridTextColumn Header="會議主旨" Binding="{Binding Subject}" Width="*" IsReadOnly="True"/>

                        <!-- 開始時間 -->
                        <DataGridTextColumn Header="開始時間"
                                            Binding="{Binding StartTime, StringFormat=yyyy/MM/dd HH:mm}"
                                            Width="140" IsReadOnly="True"/>

                        <!-- 結束時間 -->
                        <DataGridTextColumn Header="結束時間"
                                            Binding="{Binding EndTime, StringFormat=yyyy/MM/dd HH:mm}"
                                            Width="140" IsReadOnly="True"/>

                        <!-- 重複警告 -->
                        <DataGridTemplateColumn Header="重複警告" Width="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                Visibility="{Binding IsDuplicate, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="⚠ " Foreground="Orange" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding DuplicateWarning}" Foreground="OrangeRed"
                                                   VerticalAlignment="Center" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>

                    <!-- 無資料提示 -->
                    <DataGrid.Style>
                        <Style TargetType="DataGrid">
                            <Style.Triggers>
                                <Trigger Property="HasItems" Value="False">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate>
                                                <TextBlock Text="尚無會議資料，請設定日期區間後點擊「取得會議」"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Foreground="Gray" FontSize="14"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Style>
                </DataGrid>
            </Grid>
        </GroupBox>

        <!-- ── 底部按鈕列 ── -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="確定（建立 Task）" Command="{Binding ConfirmCommand}"
                    Width="140" Height="32" FontSize="13"/>
        </StackPanel>
    </Grid>
</Window>
