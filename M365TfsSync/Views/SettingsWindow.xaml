<Window x:Class="M365TfsSync.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="應用程式設定"
        Width="480" Height="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- TFS 伺服器 URL -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="TFS 伺服器 URL：" VerticalAlignment="Center" Margin="0,0,8,8"/>
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding TfsServerUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

        <!-- TFS 專案名稱 -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="TFS 專案名稱：" VerticalAlignment="Center" Margin="0,0,8,8"/>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TfsProjectName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

        <!-- AD 網域名稱 -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="AD 網域名稱：" VerticalAlignment="Center" Margin="0,0,8,8"/>
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding AdDomain, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

        <!-- 狀態訊息 -->
        <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                   Text="{Binding StatusMessage}"
                   Foreground="DarkBlue"
                   Margin="0,4,0,8"
                   TextWrapping="Wrap"/>

        <!-- 按鈕列 -->
        <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="測試連線" Command="{Binding TestConnectionCommand}"
                    Width="80" Margin="0,0,8,0"/>
            <Button Content="儲存" Command="{Binding SaveCommand}"
                    Width="60" Margin="0,0,8,0"/>
            <Button Content="取消" Command="{Binding CancelCommand}"
                    Width="60"/>
        </StackPanel>
    </Grid>
</Window>
